WEBDAV_USERNAME=xxx
WEBDAV_PASSWORD=xxx
WEBDAV_URL=http://xxx:yyy/remote.php/webdav
INPUT_DIR='input/'
OUTPUT_DIR='preprocessed/'
PREPROCESSED_IMAGE_EXTENSION='png'
OPENAI_API_KEY=sk-xxx
POSTGRESQL_HOST=xxx
POSTGRESQL_PORT=xxx
POSTGRESQL_USER=xxx
POSTGRESQL_PASSWORD=xxx
POSTGRESQL_DB=xxx
MODEL=gpt-5
MINIO_ENDPOINT=xxx:yyy
MINIO_ACCESS_KEY=xxx
MINIO_SECRET_KEY=xxx
MINIO_BUCKET=eye-budget
MINIO_SECURE=false

# Redis (broker + result backend for Celery)
REDIS_URL=redis://localhost:6379/0

# Soketi (self-hosted Pusher-compatible WebSocket server)
SOKETI_APP_ID=eye-budget
SOKETI_APP_KEY=eye-budget-key
SOKETI_APP_SECRET=eye-budget-secret
SOKETI_HOST=localhost
SOKETI_PORT=6001

# Frontend (NEXT_PUBLIC_ vars are exposed to the browser)
NEXT_PUBLIC_PUSHER_KEY=eye-budget-key
NEXT_PUBLIC_PUSHER_WS_HOST=localhost
NEXT_PUBLIC_PUSHER_WS_PORT=6001